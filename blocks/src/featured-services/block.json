{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "ecs/featured-services",
  "version": "0.1.0",
  "title": "Featured Services",
  "category": "theme",
  "icon": "store",
  "description": "Displays featured services pulled from WooCommerce products.",
  "supports": {
    "html": false,
    "color": {
      "background": false,
      "text": false
    },
    "spacing": {
      "margin": true,
      "padding": true
    }
  },
  "attributes": {
    "count": {
      "type": "number",
      "default": 3
    }
  },
  "textdomain": "elevation-career-services",
  "editorScript": "file:./index.js",
  "style": "file:./style-index.scss",
  "render": "file:./render.php"
}
