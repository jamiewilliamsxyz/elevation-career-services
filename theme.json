{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "color": {
      "palette": [
        { "slug": "primary", "color": "#1B4FFF", "name": "Primary" },
        { "slug": "primary-dark", "color": "#1338CC", "name": "Primary Dark" },
        { "slug": "accent", "color": "#F5A623", "name": "Accent" },
        { "slug": "background", "color": "#F9FAFB", "name": "Background" },
        { "slug": "text", "color": "#1A1A2E", "name": "Text" },
        { "slug": "neutral-mid", "color": "#6B7280", "name": "Neutral Mid" },
        { "slug": "white", "color": "#FFFFFF", "name": "White" }
      ],
      "custom": false,
      "defaultPalette": false
    },
    "typography": {
      "fontSizes": [
        { "slug": "small", "size": "14px", "name": "Small" },
        { "slug": "normal", "size": "16px", "name": "Normal" },
        { "slug": "large", "size": "20px", "name": "Large" },
        { "slug": "x-large", "size": "32px", "name": "XL" },
        { "slug": "xx-large", "size": "48px", "name": "XXL" }
      ],

      "fontFamilies": [
        {
          "slug": "heading",
          "fontFamily": "'Playfair Display', serif",
          "name": "Heading Font"
        },
        {
          "slug": "body",
          "fontFamily": "'Inter', sans-serif",
          "name": "Body Font"
        }
      ],

      "defaultFontSizes": false
    }
  },

  "styles": {
    "color": {
      "background": "var(--wp--preset--color--background)",
      "text": "var(--wp--preset--color--text)"
    },

    "typography": {
      "fontFamily": "var(--wp--preset--font-family--body)",
      "fontSize": "var(--wp--preset--font-size--normal)",
      "fontWeight": "400"
    }
  }
}
